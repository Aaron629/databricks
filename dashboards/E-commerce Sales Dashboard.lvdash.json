{
  "datasets": [
    {
      "name": "d484ce57",
      "displayName": "Daily Revenue Summary Report",
      "queryLines": [
        "SELECT \n",
        "  DATE(created_at) AS date,\n",
        "  SUM(total_amount) AS revenue\n",
        "FROM mock_ecommerce_2000_rows\n",
        "GROUP BY date\n",
        "ORDER BY date"
      ]
    },
    {
      "name": "f17aa811",
      "displayName": "Category Revenue Summary from Ecommerce Data",
      "queryLines": [
        "SELECT \n",
        "  category,\n",
        "  SUM(total_amount) AS revenue\n",
        "FROM mock_ecommerce_2000_rows\n",
        "GROUP BY category\n",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "2d4fbc40",
      "displayName": "City Revenue Insights",
      "queryLines": [
        "SELECT \n",
        "  city,\n",
        "  SUM(total_amount) AS revenue\n",
        "FROM mock_ecommerce_2000_rows\n",
        "GROUP BY city\n",
        "ORDER BY revenue DESC"
      ]
    },
    {
      "name": "48046fc7",
      "displayName": "Member Revenue Insights",
      "queryLines": [
        "SELECT \n",
        "  is_member,\n",
        "  SUM(total_amount) AS revenue\n",
        "FROM mock_ecommerce_2000_rows\n",
        "GROUP BY is_member"
      ]
    },
    {
      "name": "4b0fb0df",
      "displayName": "Payment Method Insights and Revenue Analysis",
      "queryLines": [
        "SELECT \n",
        "  payment_method,\n",
        "  COUNT(*) AS orders,\n",
        "  SUM(total_amount) AS revenue\n",
        "FROM mock_ecommerce_2000_rows\n",
        "GROUP BY payment_method"
      ]
    }
  ],
